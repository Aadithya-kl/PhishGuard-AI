# =============================================================================
# PhishGuard AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Application ---
APP_NAME=PhishGuard AI
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
API_V1_PREFIX=/api/v1

# --- Database ---
DATABASE_URL=postgresql+asyncpg://phishguard:phishguard_secret@localhost:5432/phishguard_db
SYNC_DATABASE_URL=postgresql://phishguard:phishguard_secret@localhost:5432/phishguard_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- JWT Auth ---
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_SCAN_PER_MINUTE=10

# --- File Storage ---
UPLOAD_DIR=./uploads
REPORT_DIR=./reports
MAX_UPLOAD_SIZE_MB=25

# --- Threat Intelligence API Keys ---
# VirusTotal (https://www.virustotal.com/gui/join-us)
VIRUSTOTAL_API_KEY=

# Google Safe Browsing (https://developers.google.com/safe-browsing)
GOOGLE_SAFE_BROWSING_API_KEY=

# AbuseIPDB (https://www.abuseipdb.com/account/api)
ABUSEIPDB_API_KEY=

# PhishTank (https://phishtank.org/api_info.php)
PHISHTANK_API_KEY=

# OpenPhish (https://openphish.com/phishing_feeds.html)
OPENPHISH_FEED_URL=https://openphish.com/feed.txt

# --- AI / LLM Configuration ---
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LLM Provider: "openai" or "ollama" or "mock"
LLM_PROVIDER=mock

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Default Admin Account (created on first run) ---
ADMIN_EMAIL=admin@phishguard.ai
ADMIN_PASSWORD=PhishGuard@2024!
ADMIN_FULL_NAME=System Administrator
